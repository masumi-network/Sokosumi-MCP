# Sokosumi MCP Server Environment Variables
# Copy this file to .env and fill in your values

# ====================
# DEPLOYMENT SETTINGS
# ====================

# PORT - Set this to enable HTTP mode for remote deployment
# If not set, server runs in STDIO mode for local use
# PORT=8000

# ====================
# SOKOSUMI API ACCESS
# ====================

# Your Sokosumi API key for local stdio testing
# Get this from your Sokosumi dashboard: https://app.sokosumi.com
# Hosted MCP usage should authenticate with OAuth instead.
SOKOSUMI_API_KEY=your_api_key_here

# Network selection (optional, defaults to mainnet)
# Options: "mainnet" or "preprod"
# - mainnet: https://api.sokosumi.com (production)
# - preprod: https://api.preprod.sokosumi.com (testing)
SOKOSUMI_NETWORK=mainnet

# Optional API base URL overrides for local or staging work
# SOKOSUMI_API_BASE_URL=https://api.sokosumi.com
# SOKOSUMI_MAINNET_API_BASE_URL=https://api.sokosumi.com
# SOKOSUMI_PREPROD_API_BASE_URL=https://api.preprod.sokosumi.com

# ====================
# USAGE NOTES
# ====================

# Local Development:
# - Don't set PORT to use STDIO transport
# - Set SOKOSUMI_API_KEY for testing
# - Connect via Claude Desktop MCP config

# Remote Deployment (Railway/Cloud):
# - Set PORT for HTTP transport
# - API keys passed via URL: ?api_key=xxx&network=mainnet
# - Deploy to Railway/Cloud Run/etc.

# Example connection URLs:
# - Local: stdio transport via MCP client
# - Remote: https://your-server.com/mcp?api_key=xxx&network=mainnet
